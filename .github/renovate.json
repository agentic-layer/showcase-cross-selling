{
  "extends": [
    "github>agentic-layer/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/deploy/local/agent-runtime-config\.yaml$/"
      ],
      "matchStrings": [
        "\"(?<depName>ghcr\\.io\\/[^:]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
